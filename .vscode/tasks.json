{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile and Run",
            "type": "shell",
            "command": "javac ${file} && java -cp ${fileDirname} ${fileBasenameNoExtension} < input.txt > output.txt",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Compile All and Run",
            "type": "shell",
            "command": "javac ${fileDirname}/*.java && java -cp ${fileDirname} ${fileBasenameNoExtension} < input.txt > output.txt",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Compile and Run - V2",
            "type": "shell",
            "command": "java ${fileDirname}/${fileBasename} < input.txt > output.txt",
            "group": "build",
            "problemMatcher": []
        }  
    ]
}